platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # WAMR — WebAssembly Micro Runtime (interpreter mode, no JIT, App Store safe).
  # Build the xcframework first with: scripts/build-wamr-ios.sh
  wamr_xcframework = File.expand_path('WAMR/wamr.xcframework', __dir__)
  if File.exist?(wamr_xcframework)
    pod 'WAMR', :path => '.'
  end

  # C2WNet — wazero WASM runtime + gvisor-tap-vsock network stack (replaces WAMR).
  # Build with: scripts/build-c2wnet-ios.sh
  # When both C2WNet and WAMR are present, C2WNet takes priority (has networking).
  c2wnet_xcframework = File.expand_path('C2WNet/C2WNet.xcframework', __dir__)
  if File.exist?(c2wnet_xcframework)
    pod 'C2WNet', :path => '.'
  end

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  wamr_xcframework = File.expand_path('WAMR/wamr.xcframework', __dir__)
  wamr_available = File.exist?(wamr_xcframework)

  c2wnet_xcframework = File.expand_path('C2WNet/C2WNet.xcframework', __dir__)
  c2wnet_available = File.exist?(c2wnet_xcframework)

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Set WAMR_AVAILABLE and C2WNET_AVAILABLE Swift flags when xcframeworks are present.
  swift_flags = []
  swift_flags << '-DWAMR_AVAILABLE' if wamr_available
  swift_flags << '-DC2WNET_AVAILABLE' if c2wnet_available

  unless swift_flags.empty?
    installer.pods_project.targets.each do |target|
      next unless target.name == 'Pods-Runner'
      target.build_configurations.each do |config|
        flags = config.build_settings['OTHER_SWIFT_FLAGS'] || '$(inherited)'
        swift_flags.each do |f|
          next if flags.to_s.include?(f)
          flags = "#{flags} #{f}"
        end
        config.build_settings['OTHER_SWIFT_FLAGS'] = flags
      end
    end
    # Also apply to the main app target via xcconfig injection.
    runner_xcconfig = File.expand_path('Flutter/WAMR.xcconfig', __dir__)
    File.write(runner_xcconfig, "OTHER_SWIFT_FLAGS = $(inherited) #{swift_flags.join(' ')}\n")
  end
end
